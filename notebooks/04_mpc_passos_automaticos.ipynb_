{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"108srWOStdmyPsSwRg03BXRKsUYKMDQIb","timestamp":1706706040966}]},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from cvxopt import matrix, solvers\n","\n","solvers.options['show_progress'] = False"],"metadata":{"id":"yJFNx3eLnYXm"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- PARÂMETROS ---\n","Ts = 0.1\n","Tsim = 10.0\n","kend = int(Tsim / Ts)\n","X_dot_ref = 0.2\n","Y_dot_ref = 0.0\n","Y_dist = 0.12\n","h_com = 0.814\n","theta=0.0\n","g = 9.81\n","l_foot = 0.06\n","w_foot = 0.04\n","N = 50\n","Nss = 10\n","Nf = int(N / Nss)\n","\n","alpha = 1e-6 # Jerk\n","beta = 1.0  # Velocity\n","gamma = 100 # ZMP"],"metadata":{"id":"jC2D0jqOnYy1"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- MATRIZES A e B ---\n","A = np.matrix([[1, Ts, Ts**2/2],[0, 1, Ts],[0, 0, 1]])\n","\n","B = np.matrix([[Ts**3/6],[Ts**2/2],[Ts]])\n","\n","C = np.asmatrix((1, 0, -h_com/g))\n","\n","# --- MATRIZES HERDT ---\n","Pps = np.zeros((N, 3))\n","Pvs = np.zeros((N, 3))\n","Pas = np.zeros((N, 3))\n","Pzs = np.zeros((N, 3))\n","\n","Ppu = np.zeros((N, N))\n","Pvu = np.zeros((N, N))\n","Pau = np.zeros((N, N))\n","Pzu = np.zeros((N, N))\n","\n","for i in range(N):\n","    k_step = i + 1\n","    Pps[i, :] = [1, k_step*Ts, (k_step**2 * Ts**2)/2]\n","    Pvs[i, :] = [0, 1, k_step*Ts]\n","    Pas[i, :] = [0, 0, 1]\n","    Pzs[i, :] = [1, k_step*Ts, (k_step**2 * Ts**2)/2 - h_com/g]\n","\n","    for j in range(N):\n","        if i >= j:\n","          diff = i - j\n","          Ppu[i, j] = (1 + 3*diff + 3*diff**2) * (Ts**3 / 6)\n","          Pvu[i, j] = (1 + 2*diff) * (Ts**2 / 2)\n","          Pau[i, j] = Ts\n","          Pzu[i, j] = (1 + 3*diff + 3*diff**2) * (Ts**3 / 6) - (h_com * Ts / g)"],"metadata":{"id":"A9F5vFM9nY1t"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- FUNÇÕES AUXILIARES ---\n","\n","def get_U_Uc(N, Nss, kl, Nf):\n","   Uk_c = np.zeros((N, 1))\n","   Uk = np.zeros((N, Nf))\n","   rem_ss = Nss - kl\n","   for i in range(1, N + 1):\n","      if i <= rem_ss:\n","          Uk_c[i-1, 0] = 1\n","      else:\n","        foot_idx = int(np.ceil((i - rem_ss) / Nss))\n","        if foot_idx <= Nf:\n","          Uk[i-1, foot_idx-1] = 1\n","        else:\n","          Uk[i-1, Nf-1] = 1\n","   return np.matrix(Uk), np.matrix(Uk_c)\n","\n","\n","\n","def create_Gcoll(Nf):\n","    size = Nf + 1\n","    Gcoll = np.zeros((size, size))\n","    for i in range(size):\n","        if i == 0:\n","            Gcoll[i, 0] = 1\n","        else:\n","\n","            sign = (-1)**(i)\n","            Gcoll[i, i] = 1 * sign\n","            Gcoll[i, i-1] = -1 * sign\n","    return Gcoll"],"metadata":{"id":"DTpARJejnY4-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- INICIALIZAÇÃO DA SIMULAÇÃO ---\n","x_CoM = np.zeros((3, kend))\n","y_CoM = np.zeros((3, kend))\n","Xf_log = []\n","Yf_log = []\n","ZMPX_real = []\n","ZMPY_real = []\n","kl = 0\n","Xk_fc = 0.0\n","Yk_fc = Y_dist / 2.0\n","y_CoM[0, 0] = Yk_fc\n","feet = 0\n","Gcoll = create_Gcoll(Nf)"],"metadata":{"id":"iKWURu4fnY8V"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Matrizes para restrições\n","Dsx_single = np.matrix([[1.0], [-1.0]])\n","Dsx = np.kron(np.eye(N), Dsx_single)\n","Ys = 0\n","s_feet = np.matrix([[l_foot/2], [l_foot/2]])\n","w_feet = np.matrix([[w_foot/2], [w_foot/2]])\n","\n","A_acc_ineq = np.vstack([Pau, -Pau])\n","A_acc_total = np.hstack([A_acc_ineq, np.zeros((2*N, Nf))])\n"],"metadata":{"id":"rMqQgTrUn6jn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- CONFIGURAÇÕES DO EMPURRÃO (Defina antes do loop for) ---\n","empurrao = True\n","k_empurrao1 = 25\n","k_empurrao2 = 29     # O step exato (instante k) em que o robô sofre o empurrão\n","pert_accel_x = -0.09      # Intensidade da perturbação de aceleração no eixo X\n","pert_accel_y = 0.0     # Intensidade da perturbação de aceleração no eixo Y (opcional)\n","\n","for k in range(kend-1):\n","    xk_CoM = x_CoM[:, k].reshape(3, 1)\n","    yk_CoM = y_CoM[:, k].reshape(3, 1)\n","\n","\n","\n","    # Obter matrizes variantes no tempo\n","    Uk, Uk_c = get_U_Uc(N, Nss, kl, Nf)\n","\n","    # Construir QP (H e f)\n","    H11 = alpha*np.eye(N) + beta*(Pvu.T @ Pvu) + gamma*(Pzu.T @ Pzu)\n","    H12 = -gamma*(Pzu.T @ Uk)\n","    H21 = H12.T\n","    H22 = gamma*(Uk.T @ Uk)\n","\n","    epsilon = 1e-9\n","    Hqp = matrix(np.block([[H11, H12], [H21, H22]]) + np.eye(N + Nf) * epsilon)\n","\n","    # fqp\n","    f1 = beta * Pvu.T @ (Pvs @ xk_CoM - X_dot_ref) + gamma * Pzu.T @ (Pzs @ xk_CoM - Uk_c * Xk_fc)\n","    f2 = -gamma * Uk.T @ (Pzs @ xk_CoM - Uk_c * Xk_fc)\n","    fqp = matrix(np.vstack([f1, f2]))\n","\n","    # Restrições ZMP\n","    A_zmp = np.hstack([Dsx @ Pzu, -Dsx @ Uk])\n","    b_zmp = np.tile(s_feet, (N, 1)) + Dsx @ (Uk_c * Xk_fc) - Dsx @ (Pzs @ xk_CoM)\n","\n","    # Restrições Aceleração\n","    b_acc = np.vstack([np.ones((N,1)) - Pas@xk_CoM,np.ones((N,1)) + Pas@xk_CoM])\n","\n","    A_total = matrix(np.vstack([A_acc_total, A_zmp]))\n","    b_total = matrix(np.vstack([b_acc, b_zmp]))\n","    # 4. Resolver\n","    sol_x = solvers.qp(Hqp, fqp, A_total, b_total)\n","    u_x = sol_x['x'][0]\n","\n","    # 5. Evoluir Dinâmica\n","    x_CoM[:, k+1] = (A @ xk_CoM + B * u_x).flatten()\n","\n","    # Log ZMP Real\n","\n","    Xf_log.append(Xk_fc)\n","\n","    # -----------------------------------------------------------------------------------------------------------------------------------\n","    # logica em Y\n","\n","    # fqp\n","    fa = beta*Pvu.T @ (Pvs @ yk_CoM - Y_dot_ref) + gamma*Pzu.T @ (Pzs @ yk_CoM - Uk_c*Yk_fc)\n","    fb = -gamma*Uk.T @ (Pzs @ yk_CoM - Uk_c*Yk_fc)\n","    fy = matrix(np.vstack([fa,fb]))\n","\n","    # Restrições ZMP\n","    A_zmp = np.hstack([Dsx @ Pzu, -Dsx @ Uk])\n","    b_zmp = np.tile(w_feet, (N, 1)) + Dsx @ (Uk_c*Yk_fc) - Dsx @ (Pzs @ yk_CoM)\n","\n","    # Restrições Aceleração\n","    b_acc = np.vstack([np.ones((N,1)) - Pas@yk_CoM,np.ones((N,1)) + Pas@yk_CoM])\n","\n","    # Restrições feet colision\n","    Gcoll_f = Gcoll[1:, 1:]\n","\n","    A_coll_y = np.hstack([np.zeros((Nf, N)), ((-1)**feet) * Gcoll_f  ])\n","    dc_x = -np.sin(theta)\n","    dc_y = np.cos(theta)\n","    b_coll_y = -np.ones((Nf, 1)) * Y_dist\n","\n","    if (Y_dot_ref>=0 and feet == 1):\n","      b_coll_y[0, 0] -= ((-1)**feet) * (dc_x * Xk_fc + dc_y * Yk_fc)\n","    else:\n","      if (Y_dot_ref<0 and feet == 0):\n","        b_coll_y[0, 0] -= ((-1)**feet) * (dc_x * Xk_fc + dc_y * Yk_fc)\n","\n","    A_total_y = matrix(np.vstack([A_acc_total, A_zmp, A_coll_y]))\n","    b_total_y = matrix(np.vstack([b_acc, b_zmp, b_coll_y]))\n","\n","    sol_y = solvers.qp(Hqp, fy, A_total_y, b_total_y)\n","    u_y = sol_y['x'][0]\n","\n","    # 5. Evoluir Dinâmica\n","    y_CoM[:, k+1] = (A @ yk_CoM + B * u_y).flatten()\n","\n","\n","    Yf_log.append(Yk_fc)\n","\n","    x_next = A @ xk_CoM + B * u_x\n","    y_next = A @ yk_CoM + B * u_y\n","\n","    # O empurrão altera a aceleração física do robô na transição para o próximo passo\n","    if empurrao and k > k_empurrao1 and k < k_empurrao2:\n","        x_CoM[1, k+1] += pert_accel_x\n","        y_CoM[1, k+1] += pert_accel_y\n","        print((C@xk_CoM)[0,0])\n","\n","    ZMPX_real.append((C@xk_CoM)[0,0])\n","    ZMPY_real.append((C@yk_CoM)[0,0])\n","    # 6. Lógica de Troca de Pé\n","    if kl == Nss:\n","       Xk_fc = sol_x['x'][N]\n","       Yk_fc = sol_y['x'][N]\n","       Ys = sol_y['x'][N:]\n","       kl = 0\n","       feet = 1 if feet < 1 else 0\n","    else:\n","       kl += 1"],"metadata":{"id":"mEH7P01pn6dn","executionInfo":{"status":"ok","timestamp":1771965034849,"user_tz":180,"elapsed":977,"user":{"displayName":"Paulo Botelho","userId":"06132952035658643288"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"0f212a74-147d-4a5d-ce51-42ce9c0469e0"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["0.3763978527870818\n","0.37645752618273004\n","0.3587827685387758\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import matplotlib.patches as patches\n","import numpy as np\n","from google.colab import files\n","\n","# ==========================================\n","# --- CONFIGURAÇÃO DE FONTE PARA O TCC ---\n","# ==========================================\n","\n","plt.rcParams.update({\n","    'font.family': 'serif',\n","    'mathtext.fontset': 'cm',\n","    'font.size': 12,\n","    'axes.titlesize': 12, # Título do gráfico ativado\n","    'axes.labelsize': 12,\n","    'xtick.labelsize': 10,\n","    'ytick.labelsize': 10,\n","    'legend.fontsize': 10,\n","    'figure.figsize': (6.5, 3.5)\n","})\n","\n","# ==========================================\n","# --- PARÂMETROS DE CONTROLE E SIMULAÇÃO ---\n","# ==========================================\n","# Mude para True quando rodar a simulação com a perturbação\n","prefixo = 'Herdt'\n","\n","# --- >>> AJUSTE AQUI O TEMPO DE INÍCIO <<< ---\n","# Em que segundo a perturbação começa? (ex: 2.0s, 4.5s)\n","t_perturb_start = 2.6\n","\n","fig_size = (6.5, 3.5)\n","l_foot = 0.06\n","w_foot = 0.04\n","\n","time = np.linspace(0, Tsim, kend)\n","\n","# Função auxiliar para adicionar a seta de perturbação\n","def add_perturbation_arrow(ax, time_vec, data_vec, t_start):\n","    # Encontra o índice no vetor de tempo mais próximo do tempo de início\n","    idx_p = (np.abs(time_vec - t_start)).argmin()\n","\n","    ax.annotate('',\n","                 xy=(time_vec[idx_p], data_vec[idx_p]), xycoords='data', # Aponta para o dado\n","                 xytext=(0, 32), textcoords='offset points', # Texto deslocado para cima\n","                 fontsize=9, color='red', ha='center',\n","                 arrowprops=dict(arrowstyle=\"->\", color='red', linewidth=1.3))\n","\n","\n","# ==========================================\n","# --- EIXO X (Frontal) ---\n","# ==========================================\n","fig1, ax1 = plt.subplots(figsize=fig_size)\n","ax1.set_title(\"Eixo X (Frontal)\") # Título de volta\n","ax1.plot(time, x_CoM[0,:], label=\"CoM X\", color='blue')\n","ax1.step(time[:-1], Xf_log, 'r--', label=\"Passo X\", where='post')\n","ax1.plot(time[:-1], ZMPX_real, 'g', alpha=0.5, label=\"ZMP Real\")\n","\n","# Adiciona seta se houver empurrão\n","if empurrao:\n","    add_perturbation_arrow(ax1, time, x_CoM[0,:], t_perturb_start)\n","\n","ax1.set_xlabel(\"Tempo [s]\")\n","ax1.set_ylabel(\"X [m]\")\n","ax1.legend()\n","ax1.grid(True)\n","plt.tight_layout()\n","\n","nome_fig1 = f'{prefixo}_per_eixo_x.pdf' if empurrao else f'{prefixo}_eixo_x.pdf'\n","fig1.savefig(nome_fig1, bbox_inches='tight')\n","plt.close(fig1)\n","\n","# ==========================================\n","# --- EIXO Y (Lateral) ---\n","# ==========================================\n","fig2, ax2 = plt.subplots(figsize=fig_size)\n","ax2.set_title(\"Eixo Y (Lateral)\") # Título de volta\n","ax2.plot(time, y_CoM[0,:], label=\"CoM Y\", color='blue')\n","ax2.step(time[:-1], Yf_log, 'r--', label=\"Passo Y\", where='post')\n","ax2.plot(time[:-1], ZMPY_real, 'g', alpha=0.5, label=\"ZMP Real\")\n","\n","# Adiciona seta se houver empurrão\n","if empurrao:\n","    add_perturbation_arrow(ax2, time, y_CoM[0,:], t_perturb_start)\n","\n","ax2.set_xlabel(\"Tempo [s]\")\n","ax2.set_ylabel(\"Y [m]\")\n","ax2.legend()\n","ax2.grid(True)\n","plt.tight_layout()\n","\n","nome_fig2 = f'{prefixo}_per_eixo_y.pdf' if empurrao else f'{prefixo}_eixo_y.pdf'\n","fig2.savefig(nome_fig2, bbox_inches='tight')\n","plt.close(fig2)\n","\n","# ==========================================\n","# --- VISTA SUPERIOR (XY) COM RETÂNGULOS ---\n","# ==========================================\n","fig3, ax3 = plt.subplots(figsize=(6.5, 4.5))\n","ax3.set_title(\"Vista Superior (XY) - Geometria dos Pés\") # Título de volta\n","ax3.plot(x_CoM[0,:], y_CoM[0,:], label=\"CoM\", color='blue', zorder=10)\n","\n","def add_foot_rectangle(ax, x, y, l, w, foot_color):\n","    rect = patches.Rectangle((x - l/2, y - w/2), l, w,\n","                             linewidth=1.5, edgecolor=foot_color,\n","                             facecolor=foot_color, alpha=0.3, zorder=5)\n","    ax.add_patch(rect)\n","\n","step_count = 0\n","for k in range(len(Xf_log)):\n","    if k == 0 or Xf_log[k] != Xf_log[k-1] or Yf_log[k] != Yf_log[k-1]:\n","        color = 'red' if step_count % 2 == 0 else 'green'\n","        add_foot_rectangle(ax3, Xf_log[k], Yf_log[k], l_foot, w_foot, color)\n","        step_count += 1\n","\n","ax3.set_xlabel(\"X [m]\")\n","ax3.set_ylabel(\"Y [m]\")\n","ax3.axis(\"equal\")\n","ax3.grid(True)\n","ax3.legend()\n","plt.tight_layout()\n","\n","nome_fig3 = f'{prefixo}_per_passos.pdf' if empurrao else f'{prefixo}_passos.pdf'\n","fig3.savefig(nome_fig3, bbox_inches='tight')\n","plt.close(fig3)\n","\n","# ==========================================\n","# --- DOWNLOAD AUTOMÁTICO ---\n","# ==========================================\n","files.download(nome_fig1)\n","files.download(nome_fig2)\n","files.download(nome_fig3)\n","\n","print(f\"Gráficos gerados (Empurrão={empurrao}), com títulos e setas, e baixados com sucesso!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":34},"id":"BChxCuN-n6XX","executionInfo":{"status":"ok","timestamp":1771965035899,"user_tz":180,"elapsed":1049,"user":{"displayName":"Paulo Botelho","userId":"06132952035658643288"}},"outputId":"01bd8980-bab8-4d5b-aba8-121b04bd2937"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_b2bfdf3f-a6c5-4b38-939d-bf48dd6515ac\", \"Herdt_per_eixo_x.pdf\", 15805)"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_6f2ba421-d939-4ca1-8fef-59756b01fe73\", \"Herdt_per_eixo_y.pdf\", 15394)"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_4e903019-3490-427c-920f-4047030c3325\", \"Herdt_per_passos.pdf\", 15924)"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Gráficos gerados (Empurrão=True), com títulos e setas, e baixados com sucesso!\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"W9IUmZ7LvAc9"},"execution_count":null,"outputs":[]}]}
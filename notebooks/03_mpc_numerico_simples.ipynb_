{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"108srWOStdmyPsSwRg03BXRKsUYKMDQIb","timestamp":1706706040966}],"authorship_tag":"ABX9TyMpRiYgL8E5aARTOH0eMtBk"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"_ZbCxhbWYjW3"},"outputs":[],"source":["import numpy as np\n","import matplotlib.pyplot as plt\n","from numpy.linalg import inv\n","from cvxopt import matrix, solvers"]},{"cell_type":"code","source":["# Parametros\n","\n","dist_y = 0.4\n","dist_x = 0.2\n","n_step = 9\n","step_pos =np.array([[0.0, 0.0]])\n","sinal = 1\n","for i in range(n_step):\n","\n","    if i==0:\n","\n","      dist_y=0.2\n","    else:\n","      sinal=-1*sinal\n","      dist_y = 0.4\n","\n","    new_pos = np.array([[step_pos[i][0] + dist_x, step_pos[i][1] + sinal*dist_y]])\n","    step_pos = np.vstack((step_pos, new_pos))\n","\n","\n","\n","\n","\n","zc = 0.4\n","g = 9.81\n","dt = 0.01\n","t_step = 1\n","\n","\n","\n","t_sim = n_step*t_step - t_step - dt\n","\n","K_preview = int(t_step/dt)\n","K_sim = int(t_sim/dt)\n","\n","N=K_preview"],"metadata":{"id":"G8fEPZyeb72X"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# trajetoria ZMP\n","ZMP_x_ref = []\n","ZMP_y_ref = []\n","i = 0\n","for t in  np.arange(0, n_step*t_step, dt):\n","    ZMP_x_ref.append(step_pos[i,0])\n","    ZMP_y_ref.append(step_pos[i,1])\n","\n","    if (t != 0) and (t%t_step < 1e-6):\n","        i += 1\n"],"metadata":{"id":"1s4J9aXwIf-6"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Matriz A e B\n","\n","A = np.asmatrix(([1, dt, dt**2/2],\n","            [0, 1, dt],\n","            [0, 0, 1]))\n","\n","B = np.asmatrix((dt**3/6, dt**2/2, dt)).T\n","\n","C = np.asmatrix((1, 0, -zc/g))\n"],"metadata":{"id":"1UOp5mGscSf-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Criando as matrizes Ps\n","\n","P_ps = np.zeros((N,3))\n","P_pu = np.zeros((N,N))\n","P_vs = np.zeros((N,3))\n","P_vu = np.zeros((N,N))\n","P_as = np.zeros((N,3))\n","P_au = np.zeros((N,N))\n","P_zs = np.zeros((N,3))\n","P_zu = np.zeros((N,N))"],"metadata":{"id":"c3oAHHkgfTs8"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Calculo das matrizes Ps\n","\n","aux = np.zeros((N,1))\n","\n","# P_ps e P_pu\n","for j in range (N):\n","    P_ps[j] = np.array([1, (j+1)*dt, ((j+1)**2 * dt**2)/2])\n","\n","    aux[j] = (1/6 + (j+1)/2 + ((j+1)**2)/2) * (dt**3)\n","\n","    for k in range(N):\n","        if j < k:\n","            P_pu[j,k] = 0\n","        else:\n","            P_pu[j,j-k] = aux[k]\n","\n","# P_vs e P_vu\n","for j in range (N):\n","        P_vs[j] = np.array([0, 1, (j+1)*dt])\n","\n","        aux[j] = (1/2 + (j+1)) * (dt**2)\n","\n","        for k in range(N):\n","            if j < k:\n","                P_vu[j,k] = 0\n","            else:\n","                P_vu[j,j-k] = aux[k]\n","\n","# P_as e P_au\n","for j in range (N):\n","        P_as[j] = np.array([0, 0, 1])\n","\n","        aux[j] = dt\n","\n","        for k in range(N):\n","            if j < k:\n","                P_au[j,k] = 0\n","            else:\n","                P_au[j,j-k] = aux[k]\n","\n","# P_zs e P_zu\n","for j in range (N):\n","    P_zs[j] = np.array([1, (j+1)*dt, (((j+1)**2) * (dt**2))/2 - zc/g])\n","\n","    aux[j] = (((1 + 3*(j) + 3*(j)**2)*(dt**3))/6) - ((zc*dt)/g)\n","\n","    for k in range(N):\n","        if j < k:\n","            P_zu[j,k] = 0\n","        else:\n","            P_zu[j,j-k] = aux[k]\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yugWrlBfiFhG","executionInfo":{"status":"ok","timestamp":1764618753073,"user_tz":180,"elapsed":36,"user":{"displayName":"Paulo Botelho","userId":"06132952035658643288"}},"outputId":"d5f2a2b2-a76a-4f27-eac6-1b42f0438f87"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-69127028.py:15: DeprecationWarning: Conversion of an array with ndim > 0 to a scalar is deprecated, and will error in future. Ensure you extract a single element from your array before performing this operation. (Deprecated NumPy 1.25.)\n","  P_pu[j,j-k] = aux[k]\n","/tmp/ipython-input-69127028.py:27: DeprecationWarning: Conversion of an array with ndim > 0 to a scalar is deprecated, and will error in future. Ensure you extract a single element from your array before performing this operation. (Deprecated NumPy 1.25.)\n","  P_vu[j,j-k] = aux[k]\n","/tmp/ipython-input-69127028.py:39: DeprecationWarning: Conversion of an array with ndim > 0 to a scalar is deprecated, and will error in future. Ensure you extract a single element from your array before performing this operation. (Deprecated NumPy 1.25.)\n","  P_au[j,j-k] = aux[k]\n","/tmp/ipython-input-69127028.py:51: DeprecationWarning: Conversion of an array with ndim > 0 to a scalar is deprecated, and will error in future. Ensure you extract a single element from your array before performing this operation. (Deprecated NumPy 1.25.)\n","  P_zu[j,j-k] = aux[k]\n"]}]},{"cell_type":"code","source":["# Criando x e y\n","\n","COM_x = np.asmatrix(np.zeros((3, K_sim+1)))\n","COM_y = np.asmatrix(np.zeros((3, K_sim+1)))\n","ux = np.asmatrix(np.zeros((K_sim, 1)))\n","uy = np.asmatrix(np.zeros((K_sim, 1)))\n","\n","\n","COM_x_H = []\n","COM_y_H = []\n","ZMP_x_H = []\n","ZMP_y_H = []\n","\n","\n","\n","Z_xref = np.zeros((N,1))\n","Z_yref = np.zeros((N,1))\n","\n","for i in range(N):\n","    Z_xref[i] = i*0.2\n","    Z_yref[i] = 0.2 if i%2==1 else -0.2\n","\n"],"metadata":{"id":"d70QvL2RIISi"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["gamma = 145\n","alpha = 1\n","aux1= np.zeros((N,1))\n","Ql = alpha * np.eye(N) + gamma*P_zu.T*P_zu\n","q_cvx = matrix(Ql)\n","q_cvy = matrix(Ql)\n","\n","\n","for k in range(799):\n","    ZMP_x_step = np.asmatrix(ZMP_x_ref[k:k+K_preview]).T\n","    ZMP_y_step = np.asmatrix(ZMP_y_ref[k:k+K_preview]).T\n","\n","\n","    pk = gamma * P_zu.T*(P_zs*COM_x[:,k] - ZMP_x_step)\n","    P_cvx = matrix(pk)\n","\n","    solx = solvers.qp(q_cvx,P_cvx)\n","    X3 = np.array(solx['x'])\n","\n","    pk = gamma * P_zu.T*(P_zs*COM_y[:,k] - ZMP_y_step)\n","\n","    P_cvy = matrix(pk)\n","\n","    soly = solvers.qp(q_cvy,P_cvy)\n","    Y3 = np.array(soly['x'])\n","\n","    ux[k]=X3[0]\n","    uy[k]=Y3[0]\n","\n","    COM_x[:,k+1] = A*COM_x[:,k] + B*ux[k]\n","    COM_y[:,k+1] = A*COM_y[:,k] + B*uy[k]\n","    COM_x_H.append(COM_x[0,k])\n","    COM_y_H.append(COM_y[0,k])\n"],"metadata":{"id":"ERppHQvRRqgo"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["plt.figure()\n","plt.subplot(3,1,1)\n","plt.plot(ZMP_x_ref, 'g--', label='ZMP_x_ref')\n","plt.plot(COM_x_H, 'r--', label='COM_x')\n","plt.legend()\n","plt.subplot(3,1,2)\n","plt.plot(ZMP_y_ref, 'g--', label='ZMP_y_ref')\n","plt.plot(COM_y_H, 'r--', label='COM_y')\n","plt.legend()\n","plt.subplot(3,1,3)\n","plt.plot(ZMP_x_ref, ZMP_y_ref, 'g--', label='ZMP_ref')\n","plt.plot(COM_x_H, COM_y_H, 'r--', label='COM')\n","plt.legend()"],"metadata":{"id":"MiGtJEaRLR7q","executionInfo":{"status":"ok","timestamp":1764618755181,"user_tz":180,"elapsed":1239,"user":{"displayName":"Paulo Botelho","userId":"06132952035658643288"}},"colab":{"base_uri":"https://localhost:8080/","height":447},"outputId":"ae1b732d-a8c3-4a15-db0c-6ecf7ba839b2"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<matplotlib.legend.Legend at 0x7d0554d9c5c0>"]},"metadata":{},"execution_count":9},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]}]}